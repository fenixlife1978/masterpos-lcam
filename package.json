{
  "name": "nextn",
  "version": "0.1.2",
  "private": true,
  "description": "Sistema de Punto de Venta - MasterPOS",
  "author": "fenixlife1978",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --turbopack -p 9002",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "build": "cross-env NODE_ENV=production next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "electron": "concurrently \"npm run dev\" \"wait-on http://localhost:9002 && electron .\"",
    "electron-build": "npm run build && electron-builder",
    "electron-build-win": "npm run build && electron-builder --win",
    "electron-dist": "electron-builder",
    "deploy": "electron-builder build --win --publish always"
  },
  "build": {
    "appId": "com.masterposv1.nextn",
    "productName": "MasterPOS",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "win": {
      "icon": "public/logo-master.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "legalTrademarks": "MasterPOS"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "fenixlife1978",
      "repo": "MasterPOS"
    }
  },
  "dependencies": {
    "@genkit-ai/google-genai": "^1.28.0",
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@supabase/supabase-js": "^2.107.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "electron-pos-printer": "^1.2.8",
    "electron-updater": "^6.1.0",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^11.10.0",
    "genkit": "^1.28.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.475.0",
    "moment-timezone": "^0.6.2",
    "next": "^15.5.9",
    "patch-package": "^8.0.0",
    "react": "^19.2.7",
    "react-day-picker": "^9.11.3",
    "react-dom": "^19.2.7",
    "react-draggable": "^4.5.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-next": "^3.1.5",
    "genkit-cli": "^1.28.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.7.3",
    "wait-on": "^9.0.10"
  }
}